{
  "name": "@salt/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run build -w @salt/types && npm run build -w @salt/validation && npm run build -w @salt/db && npm run build -w @salt/domain && tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@salt/domain": "0.0.0",
    "@salt/types": "0.0.0",
    "@salt/validation": "0.0.0",
    "@vercel/blob": "^2.3.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "nodemailer": "^7.0.13",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/nodemailer": "^7.0.11",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
