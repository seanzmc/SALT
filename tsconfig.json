{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["node"]
  },
  "include": [
    "lib/prisma.ts",
    "prisma/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "archive",
    "apps",
    "node_modules",
    "packages"
  ]
}
