DATABASE_URL="postgresql://postgres:postgres@localhost:5432/clinic_buildout_tracker?schema=public"
# Active document uploads use Vercel Blob via /api/documents/upload.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_token"
SESSION_SECRET="replace-with-a-long-random-secret"
WEB_ORIGIN="http://localhost:5173"
SMTP_FROM="no-reply@example.com"
# Either set SMTP_URL or the SMTP_HOST/SMTP_PORT/SMTP_USER/SMTP_PASSWORD pair below.
# SMTP_URL="smtps://username:password@smtp.example.com:465"
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="465"
# SMTP_SECURE="true"
# SMTP_USER="username"
# SMTP_PASSWORD="password"

# Seeded credentials. Change these after first login.
SEED_OWNER_EMAIL="owner@clinicbuildout.local"
SEED_OWNER_PASSWORD="ChangeMe123!"
SEED_COLLABORATOR_EMAIL="collaborator@clinicbuildout.local"
SEED_COLLABORATOR_PASSWORD="ChangeMe123!"
# Uncomment only when you intentionally want the destructive seed script to wipe
# a non-empty database before reseeding.
# SEED_ALLOW_RESET="true"
