# Copy this file to .env.local for local Prisma CLI and local API development.
# Local dev commands now require .env.local and intentionally ignore .env.
# Use a dedicated development database here. Never point .env.local at production.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/clinic_buildout_tracker_dev?schema=public"
# Active document uploads use Vercel Blob via /api/documents/upload.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_token"
SESSION_SECRET="replace-with-a-long-random-secret"
# Canonical web origin for production-facing links. Keep this on the active live web host
# until a custom domain is proven as the runtime surface.
WEB_ORIGIN="http://localhost:5173"
# Optional comma-separated browser origins allowed to call the API with credentials.
# Leave unset to allow only WEB_ORIGIN.
# CORS_ALLOWED_ORIGINS="http://localhost:5173,https://salt-web-opal.vercel.app"
# Optional override for password reset links. Leave unset to reuse WEB_ORIGIN.
# PASSWORD_RESET_ORIGIN="https://salt-web-opal.vercel.app"
SMTP_FROM="no-reply@example.com"
# Either set SMTP_URL or the SMTP_HOST/SMTP_PORT/SMTP_USER/SMTP_PASSWORD pair below.
# SMTP_URL="smtps://username:password@smtp.example.com:465"
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="465"
# SMTP_SECURE="true"
# SMTP_USER="username"
# SMTP_PASSWORD="password"

# Seeded credentials. Change these after first login.
SEED_OWNER_EMAIL="owner@clinicbuildout.local"
SEED_OWNER_PASSWORD="ChangeMe123!"
SEED_COLLABORATOR_EMAIL="collaborator@clinicbuildout.local"
SEED_COLLABORATOR_PASSWORD="ChangeMe123!"
# Uncomment only when you intentionally want the destructive seed script to wipe
# a non-empty database before reseeding.
# SEED_ALLOW_RESET="true"
